# api/.env.example
# Environment variables for Canopy Routes API
# Last modified: 2026-03-04

# Application environment (development | staging | production)
NODE_ENV=

# Server port (default: 3000)
PORT=3000

# PostgreSQL connection string
DATABASE_URL=postgresql://user:pass@host:5432/canopy_routes

# RS256 private key for signing JWTs
# Generate with: openssl genrsa -out private.pem 2048
JWT_PRIVATE_KEY=

# RS256 public key for verifying JWTs
# Generate with: openssl rsa -in private.pem -pubout -out public.pem
JWT_PUBLIC_KEY=

# Google Maps API key — get from Google Cloud Console
# Restrict to Geocoding API only, IP-restricted to server IP in production
GOOGLE_MAPS_API_KEY=REPLACE_WITH_KEY

# Cloudflare R2 object storage credentials
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=

# Canopy CRM integration (Phase 3 only)
CANOPY_CRM_URL=
CANOPY_CRM_API_KEY=
CANOPY_CRM_ENABLED=false

{
  "name": "canopy-routes-api",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --require ts-node/register --test src/services/zone.service.test.ts",
    "test:watch": "node --require ts-node/register --test --watch src/services/zone.service.test.ts",
    "lint": "eslint src --ext .ts",
    "migrate": "node -e \"require('ts-node').register({transpileOnly:true,skipProject:true,compilerOptions:{module:'CommonJS',target:'ES2022',esModuleInterop:true}});require('../db/migrate.ts');\""
  },
  "dependencies": {
    "bcrypt": "^5.1.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.3.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.12.0",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcrypt": "latest",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "latest",
    "@types/pg": "latest",
    "nodemon": "latest",
    "ts-node": "latest",
    "typescript": "^5.5.0"
  }
}
